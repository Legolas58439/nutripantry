// This is your Prisma schema file. It describes your database tables ("models")
// in a simple, readable language. When you run `prisma migrate`, Prisma turns
// this into real SQL tables and keeps them in sync.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// One row per item in the pantry. These fields mirror the PantryItem TypeScript
// type in lib/data/types.ts almost exactly — that's deliberate.
model PantryItem {
  id       String @id @default(uuid()) // primary key; auto-generated unique id
  ownerId  String @default("local") // who owns it — "local" until we add accounts
  name     String
  quantity Float // Float allows decimals (e.g. 1.5 kg)
  unit     String

  // Optional nutrition info (per 100g). "?" makes the column nullable.
  brand   String?
  kcal    Float?
  protein Float?
  carbs   Float?
  fat     Float?

  createdAt DateTime @default(now()) // useful for sorting newest-first later

  // An index makes "find all items for this owner" fast once there are many rows.
  @@index([ownerId])
}

// One row per "I ate this" event — the food diary that powers the tracker.
// We store the ABSOLUTE consumed values (computed at log time) so an entry is a
// stable historical record, even if the source pantry item is later edited or
// deleted.
model ConsumptionLog {
  id           String  @id @default(uuid())
  ownerId      String  @default("local")
  name         String // snapshot of the food name, e.g. "Chicken breast"
  brand        String?
  grams        Float // amount eaten, in grams
  kcal         Float   @default(0) // absolute values for this serving
  protein      Float   @default(0)
  carbs        Float   @default(0)
  fat          Float   @default(0)
  pantryItemId String? // optional link back to the pantry item it came from

  consumedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  // We query "entries for this owner within a date range", so index both.
  @@index([ownerId, consumedAt])
}

// Daily nutrition targets — one row per owner (enforced by @unique on ownerId).
model NutritionGoal {
  id        String   @id @default(uuid())
  ownerId   String   @unique @default("local")
  kcal      Float?
  protein   Float?
  carbs     Float?
  fat       Float?
  updatedAt DateTime @updatedAt
}
